# =============================================================================
# Frontbase — Environment Configuration
# =============================================================================
# Copy to .env, fill in the values, then: docker-compose up -d
# =============================================================================

# === Required ===
SECRET_KEY=change-me-in-production
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-in-production

# Your site's public URL (for preview links after publish)
# PUBLIC_URL=https://yoursite.com

# Webhook authentication keys (comma-separated)
# API_KEYS=key1,key2

# === Deployment Mode ===
# "self-host" (default) — single-tenant, env-var admin, session cookies
# "cloud"               — multi-tenant SaaS, DB-backed users, JWT auth
# DEPLOYMENT_MODE=cloud
# VITE_DEPLOYMENT_MODE=cloud

# === Cloud Mode Only — External Database URL ===
# For Supabase: Copy the connection string exactly as shown in the Dashboard (IPv4 or Session Pooler).
# The platform will automatically normalize the dialect (e.g. postgresql:// -> postgresql+psycopg2://)
# DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# === PostgreSQL (default: SQLite, uncomment to switch) ===
# COMPOSE_PROFILES=postgresql
# DB_PASSWORD=your-secure-password

# === Distributed / Multi-Machine (uncomment when splitting services) ===
# BACKEND_URL=http://MACHINE_A_IP:8000
# EDGE_URL=http://MACHINE_C_IP:3002
# ==============================================================================
# FRONTBASE STANDALONE EDGE CONFIGURATION
# ==============================================================================
# Copy this file to .env before running:
# docker-compose -f docker-compose.standalone-edge.yml up -d
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Security & Authentication (Required)
# ------------------------------------------------------------------------------
# A secure, random string (e.g. openssl rand -hex 32)
# You must provide this exact same key in the Frontbase Dashboard when 
# connecting this engine.
FRONTBASE_SYSTEM_KEY=your_secure_system_key_here

# ------------------------------------------------------------------------------
# 2. Turso State Database (Required for Standalone)
# ------------------------------------------------------------------------------
# Standalone Edge Engines run in 'cloud' mode and require a remote Turso database 
# for distributed state synchronization.
TURSO_DB_URL=libsql://your-database-name-your-org.turso.io
TURSO_DB_TOKEN=your_turso_auth_token_here

# ------------------------------------------------------------------------------
# 3. Public Domain (Optional but Recommended)
# ------------------------------------------------------------------------------
# The primary domain where this edge engine is hosted.
# Used for generating absolute URLs in embeds and webhooks.
# Do not include https://, just the domain.
PRIMARY_DOMAIN=edge.yourcompany.com

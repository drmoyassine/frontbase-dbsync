# ==============================================================================
# FRONTBASE STANDALONE EDGE CONFIGURATION
# ==============================================================================
# Copy this file to .env before running:
# docker-compose -f docker-compose.standalone-edge.yml up -d
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Dashboard Connection Settings
# ------------------------------------------------------------------------------
# You must provide these exact values in the Frontbase Dashboard when 
# connecting this engine.

# A secure, random string (e.g. openssl rand -hex 32)
FRONTBASE_SYSTEM_KEY=your_secure_system_key_here

# The primary domain where this edge engine is hosted (used for the Engine URL).
# Do not include https://, just the domain.
PRIMARY_DOMAIN=edge.yourcompany.com

# ------------------------------------------------------------------------------
# 2. Remote State Database (Optional, for synchronized multi-node setups)
# ------------------------------------------------------------------------------
# By default, Standalone Edge Engines use their local SQLite volume for state.
# If you are scaling horizontally across multiple Edge instances behind a load balancer,
# you must configure a remote database (e.g. Postgres, Neon, Supabase, Turso) for distributed state synchronization.
# FRONTBASE_STATE_DB={"provider":"postgres", "url":"postgresql://user:password@host:5432/dbname"}

# ------------------------------------------------------------------------------
# 4. Redis Cache (Optional, for L2 caching in production)
# ------------------------------------------------------------------------------
# Accelerates database queries and enables distributed rate limiting.
# Set provider to 'redis' and supply the URL.
# FRONTBASE_CACHE={"provider":"redis", "url":"redis://default:password@host:port"}


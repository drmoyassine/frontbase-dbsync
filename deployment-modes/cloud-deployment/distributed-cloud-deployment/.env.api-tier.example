# =============================================================================
# API Tier (Machine A) Environment Variables
# =============================================================================
# Copy to .env.api-tier and fill in the values before deploying docker-compose.api-tier.yml

# === 1. Network / Cluster Topology ===
BACKEND_PORT=8000
EDGE_URL=http://MACHINE_C_IP:3002

# === 2. Cache Provider ===
# "redis"     (default) — Standard Redis cache
# "dragonfly"           — Highly performant, multi-threaded Redis drop-in replacement
CACHE_PROVIDER=redis

# Let Compose automatically boot the correct cache container
COMPOSE_PROFILES=${CACHE_PROVIDER:-redis}

# === 3. API / Backend Specific Configuration ===
# Security (REQUIRED)
SECRET_KEY=change-me-in-production
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-in-production

# Deployment Mode
# "self-host" (default) or "cloud" (multi-tenant SaaS)
DEPLOYMENT_MODE=cloud

# === Authentication Provider ===
AUTH_PROVIDER=supabase

# === Supabase Configuration (Required when AUTH_PROVIDER=supabase) ===
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_JWT_SECRET=your-jwt-secret
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database Connection (Pointing to Machine B, or Supabase Pooler)
DATABASE_URL=postgresql://frontbase:your-secure-password@MACHINE_B_IP:5432/frontbase

# Email Settings (Optional)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
# EMAIL_FROM=noreply@yourdomain.com

# Observability (Optional)
# SENTRY_DSN=

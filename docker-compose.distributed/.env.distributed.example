# =============================================================================
# Distributed Deployment — Environment Variables
# =============================================================================
# Use when splitting services across multiple machines.
# Copy to .env.distributed and fill in your remote hostnames/IPs.
# =============================================================================

# === Security (REQUIRED) ===
SECRET_KEY=change-me-in-production
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-in-production
REDIS_TOKEN=change-me-in-production

# === Machine Addresses ===
# Machine A (API): Backend + Redis
BACKEND_URL=http://MACHINE_A_IP:8000
BACKEND_PORT=8000

# Machine B (Data): PostgreSQL
# DB_PASSWORD=your-secure-password
# POSTGRES_PORT=5432

# Machine C (Edge): Edge Engine(s)
EDGE_URL=http://MACHINE_C_IP:3002
EDGE_PORT=3002

# Machine D (Static): Frontend / Nginx
# BACKEND_HOST=MACHINE_A_IP
# EDGE_HOST=MACHINE_C_IP
# FRONTEND_PORT=80

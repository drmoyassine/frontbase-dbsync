# ==============================================================================
# FRONTBASE STANDALONE EDGE CONFIGURATION
# ==============================================================================
# 1. Copy to .env
# 2. Run: docker-compose -f docker-compose.edge.yml up -d
# ==============================================================================
# --- Port Configuration ---
# Default internal port. If deploying via raw Dockerfile (Easypanel/Render),
# ensure your platform routes public traffic to this port.
PORT=3002

# --- Dashboard Connection Settings ---
# A secure, random string (e.g. openssl rand -hex 32)
FRONTBASE_SYSTEM_KEY=your_secure_system_key_here

# [OPTIONAL] The edge primary domain (e.g. edge.yourcompany.com)
# PRIMARY_DOMAIN=edge.yourcompany.com

# ------------------------------------------------------------------------------
# 2. Remote State Database (Optional, for synchronized multi-node setups)
# ------------------------------------------------------------------------------
# By default, Standalone Edge Engines use their local SQLite volume for state.
# If you are scaling horizontally across multiple Edge instances behind a load balancer,
# you must configure a remote database (e.g. Postgres, Neon, Supabase, Turso) for distributed state synchronization.
# FRONTBASE_STATE_DB={"provider":"postgres", "url":"postgresql://user:password@host:5432/dbname"}

# ------------------------------------------------------------------------------
# 3. Vault Audit Logging & Version Retention (Optional)
# ------------------------------------------------------------------------------
# Configure retention policies for the local vault audit log and version history.
# FRONTBASE_AUDIT_LOGGING=true
# FRONTBASE_AUDIT_RETENTION_DAYS=30
# FRONTBASE_AUDIT_MAX_PER_SECRET=100
# SECRET_VERSION_RETENTION=10

# ------------------------------------------------------------------------------
# 4. OCR Engine Selection (Optional)
# ------------------------------------------------------------------------------
# Select the local OCR engine. If left blank, defaults to the OCR.space API.
# Note: UI HTTP overrides set in the Dashboard will take precedence over this variable.
# Valid values: tesseract, gnu_ocrad
# OCR_ENGINE=tesseract
# =============================================================================
# Frontbase — Environment Configuration
# =============================================================================
# Copy to .env, fill in the values, then: docker-compose up -d
# =============================================================================

# === Required ===
SECRET_KEY=change-me-in-production

# ==============================================================================
# 2. ADMIN CREDENTIALS (REQUIRED)
# ==============================================================================
# The master admin user will be created/upserted using these credentials upon startup.
# Note: There are NO defaults. These variables must be provided.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-in-production

# Your site's public URL (for preview links after publish)
# PUBLIC_URL=https://yoursite.com

# === Observability (Optional; unset = telemetry off) ===
# SPA: Sentry error tracking + PostHog product analytics. Both no-op when blank
# and in self-host mode, so self-host builds ship with zero third-party telemetry.
# VITE_SENTRY_DSN=
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# Backend (FastAPI): Sentry error tracking (pure-ASGI; does not affect SSE streaming)
# SENTRY_DSN=

# === PostgreSQL (default: SQLite, uncomment to switch) ===
# COMPOSE_PROFILES=postgresql
# DB_PASSWORD=your-secure-password

# === Email Provider (Platform-Level) ===
# Pick ONE. Resend recommended for simplicity.

# Option A: Resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx

# Option B: Mailgun
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_REGION=us                     # "us" or "eu"

# Sender identity (used by whichever provider is active)
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=Frontbase
# =============================================================================
# Frontbase Cloud Edition — Environment Configuration
# =============================================================================
# Copy to .env, fill in the values, then: 
# docker compose -f docker-compose.cloud.yml up -d
# =============================================================================

# === Required ===
SECRET_KEY=change-me-in-production
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-in-production

# ⚠️  SECURITY: the three values above ship with insecure defaults so a local
# `docker compose up` works out of the box. They MUST be changed for any real
# (internet-facing) deployment. Generate SECRET_KEY with: openssl rand -hex 32

# === Public URLs (used for SuperTokens auth/email links) ===
# The backend reads BACKEND_URL to build links it emails to users (verify/reset).
# FRONTEND_URL is the SPA origin the backend redirects to after auth flows.
# Set both to your public https origins in production:
# FRONTEND_URL=https://app.yourdomain.com
# BACKEND_URL=https://api.yourdomain.com
#
# EDGE_BACKEND_URL is SEPARATE: the internal address the Edge container uses to
# reach the backend (defaults to http://backend:8000). Do NOT point it at the
# public URL — that would route edge→backend traffic out through the internet.

# Your site's public URL (for preview links after publish)
# PUBLIC_URL=https://yoursite.com

# Webhook authentication keys (comma-separated)
# API_KEYS=key1,key2

# === Authentication Provider ===
# "supertokens" (default cloud) — Email/password auth with SuperTokens
# "supabase"                    — Email/password + OAuth auth with Supabase
AUTH_PROVIDER=supertokens

# === Cache Provider ===
# "redis"     (default) — Standard Redis cache
# "dragonfly"           — Highly performant, multi-threaded Redis drop-in replacement
CACHE_PROVIDER=redis

# Automatically boot local containers based on selected providers
COMPOSE_PROFILES=${AUTH_PROVIDER:-supertokens},${CACHE_PROVIDER:-redis}

# === Supabase Configuration (Required when AUTH_PROVIDER=supabase) ===
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_JWT_SECRET=your-jwt-secret
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === External Database URL (Required when AUTH_PROVIDER=supabase) ===
# For Supabase: Copy the connection string exactly as shown in the Dashboard (IPv4 or Session Pooler).
# The platform will automatically normalize the dialect (e.g. postgresql:// -> postgresql+psycopg2://)
# DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# === Observability (Optional; unset = telemetry off) ===
# SPA: Sentry error tracking + PostHog product analytics. 
# VITE_SENTRY_DSN=
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# Backend (FastAPI): Sentry error tracking
# SENTRY_DSN=

# === Email Provider (Platform-Level) ===
# Pick ONE. Resend recommended for simplicity.

# Option A: Resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx

# Option B: Mailgun
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_REGION=us                     # "us" or "eu"

# Sender identity (used by whichever provider is active)
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=Frontbase

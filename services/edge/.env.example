# ==============================================================================
# FRONTBASE EDGE ENGINE - STANDALONE CONFIGURATION
# ==============================================================================

# Server Configuration
PORT=3002
NODE_ENV=production

# === Database Configuration ===
# (By default, uses SQLite files mounted in the /app/data volume)
SQLITE_PATH=/app/data/edge.db
DATABASE_URL=file:/app/data/edge.db
PAGES_DB_URL=file:/app/data/pages.db

# === Local Vault Encryption (Standalone Engines) ===
# FRONTBASE_SYSTEM_KEY is the master encryption key for the local vault.
# It encrypts all secrets stored in the edge_secrets table at rest.
# Generate a strong random key and never rotate it without proper backup.
# Required for standalone vault engines; unset = vault disabled (legacy .env mode).
FRONTBASE_SYSTEM_KEY=generate-a-random-32-byte-key

# === Security & Authentication ===
# Comma-separated list of Bearer tokens allowed to deploy configurations to this edge node.
# The Master Backend uses this to authenticate when calling /api/import
# For standalone vault engines, this is managed via FRONTBASE_API_KEYS (see below).
API_KEYS=your_secure_edge_key_here,another_optional_key

# === Public URL ===
# Used for generating absolute links (e.g. for embeds or webhooks).
# Leave empty to auto-detect from incoming requests.
# PUBLIC_URL=https://my-edge.company.com

# === Optional Redis / BullMQ Settings ===
# (if using external caching/queuing instead of built-in SQLite)
# REDIS_URL=redis://your-redis-host:6379

# ==============================================================================
# VAULT SECRET CLASSIFICATION (Tier 1 / Tier 2 / Tier 3)
# ==============================================================================
# Secrets are classified into tiers that determine when they're loaded:
#
# Tier 1 (Boot-Critical) — Loaded EAGERLY at engine startup
#   These are required for the engine to initialize its core providers.
#   - FRONTBASE_DATASOURCES  — Datasource connections
#   - FRONTBASE_STORAGE      — Storage provider configs
#   - FRONTBASE_CACHE        — Cache provider (Redis, Upstash, etc.)
#   - FRONTBASE_QUEUE        — Queue provider (QStash, etc.)
#   - FRONTBASE_SECRETS_KEY  — Per-worker encryption key (community engines)
#   - FRONTBASE_SECRETS_KEY_OLD — Old key during rotation window
#
# Tier 2 (Operational) — Background-loaded shortly after boot (async accessors)
#   These are important but not required for immediate boot.
#   Loaded via the background prewarm task or on-demand via getXxxConfigAsync().
#   - FRONTBASE_AUTH          — Auth/JWT config (multi-tenant)
#   - FRONTBASE_API_KEYS      — System key + API key hashes
#   - FRONTBASE_SECURITY      — Security settings
#   - FRONTBASE_AGENT_PROFILES — AI agent personas
#   - FRONTBASE_VECTOR        — Vector DB configs
#   - FRONTBASE_GPU           — AI model registry
#
# Tier 3 (Bootstrap / Config) — NEVER loaded from vault
#   These select the providers themselves and must be in .env.
#   - FRONTBASE_STATE_DB      — State DB provider selection
#
# Example: Setting secrets via the vault (recommended for standalone engines)
# -----------------------------------------------------------------------
# Instead of putting secrets in this .env file, you can push them to the
# encrypted local vault via POST /api/config/secrets (system-key auth).
# The engine will decrypt and load them at boot according to the tier above.
#
# Example .env fallback (for non-vault deployments):
# -----------------------------------------------------------------------
# FRONTBASE_CACHE={"provider":"redis","url":"redis://localhost:6379"}
# FRONTBASE_AUTH={"provider":"supabase","url":"https://xxx.supabase.co","jwtSecret":"xxx"}
# FRONTBASE_API_KEYS={"systemKey":"your-system-key","apiKeyHashes":[{"prefix":"fb_sk","hash":"..."}]}

# =============================================================================
# Static Tier (Machine D) Environment Variables
# =============================================================================
# Copy to .env.static-tier and fill in the values before deploying docker-compose.static-tier.yml

# === 1. Network / Cluster Topology ===
FRONTEND_PORT=80
BACKEND_HOST=MACHINE_A_IP
BACKEND_PORT=8000
EDGE_HOST=MACHINE_C_IP
EDGE_PORT=3002

# === 2. Static Specific Configuration ===
# Nginx routing relies on the Network topology above. No additional secrets are required.

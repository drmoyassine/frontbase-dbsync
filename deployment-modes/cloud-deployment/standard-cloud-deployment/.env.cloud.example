# =============================================================================
# Frontbase Cloud Edition — Environment Configuration
# =============================================================================
# BATTERIES INCLUDED: `docker compose -f docker-compose.cloud.yml up -d` works
# with ZERO env vars — postgres, supertokens, and redis always run, and the
# backend wires itself to them with safe internal defaults. Everything below
# hardens or customizes that default stack.
#
# ⚠️  PaaS / panel deployments (EasyPanel, Portainer, Coolify, …): these
# platforms DO NOT read this file. Paste the vars you set into the panel's
# Environment settings for the compose service.
# =============================================================================

# =============================================================================
# 1. PRODUCTION ESSENTIALS — set these before going internet-facing
# =============================================================================

# Master admin login. If either is missing, master admin login is DISABLED
# (the backend logs a warning and every admin login 401s).
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-in-production

# App signing secret. Generate: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Password for the built-in postgres container (default: "frontbase").
# ⚠️  Postgres bakes it into postgres_data on FIRST boot — set it before the
# first deploy; changing it later requires recreating the volume (or ALTER USER).
DB_PASSWORD=change-me-in-production

# Credentials-at-rest encryption key (Connected Accounts, engine secrets,
# datasource tokens). OPTIONAL with the built-in postgres: if unset, the
# backend auto-generates one and persists it to the backend_data volume.
# ⚠️  SET IT EXPLICITLY when your database is EXTERNAL (e.g. Supabase) — the
# auto-key lives in the local volume while the encrypted data lives in the DB,
# so recreating the service/volume or migrating hosts orphans every stored
# credential (mystery 401s on WordPress/Sheets/etc.). Generate once, keep it
# forever:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=

# =============================================================================
# 2. DATABASE — defaults to the built-in postgres container
# =============================================================================
# To use Supabase/external Postgres instead, set DATABASE_URL (copy the
# Dashboard connection string verbatim; dialect is normalized automatically).
# The built-in postgres keeps running but sits idle for the backend.
# DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# =============================================================================
# 3. PUBLIC URLS — REQUIRED IN PRODUCTION for working auth links/cookies
# =============================================================================
# BACKEND_URL: used to build links emailed to users (verify/reset).
# FRONTEND_URL: the SPA origin the backend redirects to after auth flows.
# Unset = localhost fallbacks (fine for a local trial; broken for real users).
# FRONTEND_URL=https://app.yourdomain.com
# BACKEND_URL=https://app.yourdomain.com
#
# EDGE_BACKEND_URL is SEPARATE: the internal address the Edge container uses
# to reach the backend (defaults to http://backend:8000). Do NOT point it at
# the public URL — that routes edge→backend traffic out through the internet.

# Your site's public URL (for preview links after publish)
# PUBLIC_URL=https://yoursite.com

# =============================================================================
# 4. PROVIDER SWITCHES (defaults: supertokens auth + redis cache, always on)
# =============================================================================

# === Authentication Provider ===
# "supertokens" (default) — built-in email/password auth, runs locally, zero config
# "supabase"              — Supabase Auth (email/password + OAuth); requires the
#                           SUPABASE_* keys below. The built-in supertokens
#                           container keeps running but sits idle.
#AUTH_PROVIDER=supabase

# === SuperTokens Core API Key (Optional — zero-config default built in) ===
# The SuperTokens core and the backend MUST share the same key; the compose
# gives BOTH sides the same internal default (fb-internal-supertokens-key), so
# login works with nothing set here. Set this to harden production — both
# services pick it up automatically.
# ⚠️  CHARSET: only alphanumerics, '-' and '='. An underscore (or any other
# character) makes the SuperTokens core CRASH-LOOP at boot with
# "Invalid characters in API key" — the service just disappears.
# SUPERTOKENS_API_KEY=your-key-with-hyphens-only

# === Cache Provider ===
# "redis" (default) — the built-in redis container, always running.
# To switch to Dragonfly (multi-threaded Redis drop-in), set BOTH lines:
#COMPOSE_PROFILES=dragonfly
#CACHE_PROVIDER=dragonfly
# Or point at an external redis:
# REDIS_URL=redis://your-external-redis:6379

# === Supabase Configuration (Required when AUTH_PROVIDER=supabase) ===
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_JWT_SECRET=your-jwt-secret
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# 5. OPTIONAL
# =============================================================================

# === Observability (unset = telemetry off) ===
# SPA: Sentry error tracking + PostHog product analytics.
# VITE_SENTRY_DSN=
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# Backend (FastAPI): Sentry error tracking
# SENTRY_DSN=

# === Email Provider (Platform-Level) ===
# Pick ONE. Resend recommended for simplicity.

# Option A: Resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx

# Option B: Mailgun
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_REGION=us                     # "us" or "eu"

# Sender identity (used by whichever provider is active)
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=Frontbase

# =============================================================================
# Edge Tier (Machine C) Environment Variables
# =============================================================================
# Copy to .env.edge-tier and fill in the values before deploying docker-compose.edge-tier.yml

# === 1. Network / Cluster Topology ===
EDGE_PORT=3002
BACKEND_URL=http://MACHINE_A_IP:8000

# === 2. Edge Specific Configuration ===
# Dashboard Connection Settings
# A secure, random string (e.g. openssl rand -hex 32)
# The API backend must be configured with this same key to manage this edge instance.
FRONTBASE_SYSTEM_KEY=your_secure_system_key_here

# Public Domain (used for preview links)
# PUBLIC_URL=https://edge.yourcompany.com

# ------------------------------------------------------------------------------
# 3. Remote State Database (Optional, for synchronized multi-node setups)
# ------------------------------------------------------------------------------
# By default, Edge Engines use their local SQLite volume for state.
# If you are scaling horizontally across multiple Edge instances behind a load balancer,
# you must configure a remote database (e.g. Postgres, Neon, Turso) for distributed state synchronization.
# FRONTBASE_STATE_DB={"provider":"postgres", "url":"postgresql://user:password@host:5432/dbname"}

# ------------------------------------------------------------------------------
# 4. Vault Audit Logging & Version Retention (Optional)
# ------------------------------------------------------------------------------
# Configure retention policies for the local vault audit log and version history.
# FRONTBASE_AUDIT_LOGGING=true
# FRONTBASE_AUDIT_RETENTION_DAYS=30
# FRONTBASE_AUDIT_MAX_PER_SECRET=100
# SECRET_VERSION_RETENTION=10

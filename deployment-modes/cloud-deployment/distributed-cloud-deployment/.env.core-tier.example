# ==============================================================================
# Environment Configuration - Core Tier (Backend + Edge)
# ==============================================================================
# Rename this file to .env.core-tier and place it in the same directory as docker-compose.core-tier.yml
#
# This setup powers the API routing and Edge Engine for distributed frontends.

ENVIRONMENT=production

# The port where the API Gateway will be exposed
API_GATEWAY_PORT=8080

# Application Secrets
SECRET_KEY=generate_a_secure_random_string_here

# Cross-Origin Resource Sharing (CORS)
# Set this to the public URL of your Cloudflare Worker frontend (e.g., https://builder.yourdomain.com)
CORS_ORIGINS=*

# Admin Credentials
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=strong_admin_password

# Master Postgres DB (Supabase connection pooler URL)
DATABASE_URL=postgresql://postgres.yourproject:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Cache Provider (redis or dragonfly)
CACHE_PROVIDER=redis

# Let Compose automatically boot the correct cache container
COMPOSE_PROFILES=${CACHE_PROVIDER:-redis}

# Authentication Provider ("supabase" or "supertokens")
AUTH_PROVIDER=supabase

# Supabase Auth Configuration (Required if AUTH_PROVIDER=supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_JWT_SECRET=your_jwt_secret
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# SuperTokens Configuration (Required if AUTH_PROVIDER=supertokens)
# This tier has no local SuperTokens core — run one elsewhere (e.g. the data
# tier with COMPOSE_PROFILES=supertokens) and point at it. Both values must
# match the core's config.
# ⚠️  Key charset: alphanumerics, '-' and '=' ONLY. An underscore makes the
# core crash-loop at boot ("Invalid characters in API key").
# SUPERTOKENS_URI=http://your-core-host:3567
# SUPERTOKENS_API_KEY=your-key-with-hyphens-only

# =============================================================================
# Frontbase Cloud Edition — Environment Configuration
# =============================================================================
# Copy to .env, fill in the values, then:
#   docker compose -f docker-compose.cloud.yml up -d
#
# ⚠️  PaaS / panel deployments (EasyPanel, Portainer, Coolify, …): these
# platforms DO NOT read this file. Paste every non-comment line below into the
# panel's Environment settings for the compose service. If you skip this, ALL
# vars are blank — COMPOSE_PROFILES included, which makes compose silently
# SKIP the postgres/supertokens/redis services (no error, they just don't
# exist) and the backend falls back to SQLite with admin login disabled.
# =============================================================================

# =============================================================================
# 1. REQUIRED — deployment is broken without every one of these
# =============================================================================

# Which optional services to boot. MUST be set (see PaaS warning above).
# Literal form (recommended — works everywhere):
COMPOSE_PROFILES=supertokens,redis
# Compose v2 can compute it instead:  COMPOSE_PROFILES=${AUTH_PROVIDER:-supertokens},${CACHE_PROVIDER:-redis}
# ⚠️  If this is wrong/missing, `up --remove-orphans` DELETES the running
# auth-stack containers. Both "supertokens" and the legacy "postgresql"
# profile names activate the auth stack.

# App signing secret. Generate: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Credentials-at-rest encryption key (Connected Accounts, engine secrets,
# datasource tokens). OPTIONAL for a stable single-host setup: if unset, the
# backend auto-generates one and persists it to the backend_data volume
# (/app/data/.env), where it survives restarts and redeploys.
# ⚠️  SET IT EXPLICITLY when your database is EXTERNAL (e.g. Supabase) — the
# auto-key lives in the local volume while the encrypted data lives in the DB,
# so recreating the service/volume or migrating hosts orphans every stored
# credential (mystery 401s on WordPress/Sheets/etc.). Generate once, keep it
# forever:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=

# Master admin login. If either is missing, master admin login is DISABLED
# (the backend logs a warning and every admin login 401s).
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-in-production

# Postgres password for the LOCAL postgres container (supertokens profile).
DB_PASSWORD=change-me-in-production

# Backend database. Two supported setups:
#   A) Local postgres container (COMPOSE_PROFILES includes supertokens) —
#      write the SAME password as DB_PASSWORD literally (don't rely on
#      ${DB_PASSWORD} expansion inside .env; it's compose-version dependent):
DATABASE_URL=postgresql://frontbase:change-me-in-production@postgres:5432/frontbase
#   B) External/managed Postgres (e.g. Supabase — required when
#      AUTH_PROVIDER=supabase; copy the Dashboard connection string verbatim,
#      dialect is normalized automatically):
# DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# ⚠️  If DATABASE_URL is blank the backend silently falls back to SQLite in
# the container volume — your data is NOT in your real database.

# =============================================================================
# 2. PUBLIC URLS — REQUIRED IN PRODUCTION for working auth links/cookies
# =============================================================================
# BACKEND_URL: used to build links emailed to users (verify/reset).
# FRONTEND_URL: the SPA origin the backend redirects to after auth flows.
# Unset = localhost fallbacks (fine for a local trial; broken for real users).
# FRONTEND_URL=https://app.yourdomain.com
# BACKEND_URL=https://app.yourdomain.com
#
# EDGE_BACKEND_URL is SEPARATE: the internal address the Edge container uses
# to reach the backend (defaults to http://backend:8000). Do NOT point it at
# the public URL — that routes edge→backend traffic out through the internet.

# Your site's public URL (for preview links after publish)
# PUBLIC_URL=https://yoursite.com

# =============================================================================
# 3. PROVIDERS (defaults shown; override to switch)
# =============================================================================

# === Authentication Provider ===
# "supertokens" (default cloud) — Email/password auth with SuperTokens
# "supabase"                    — Email/password + OAuth auth with Supabase
#AUTH_PROVIDER=supabase

# === SuperTokens Core API Key (Optional — zero-config default built in) ===
# The SuperTokens core and the backend MUST share the same key; the compose
# gives BOTH sides the same internal default (fb-internal-supertokens-key), so
# login works with nothing set here. Set this to harden production — both
# services pick it up automatically.
# ⚠️  CHARSET: only alphanumerics, '-' and '='. An underscore (or any other
# character) makes the SuperTokens core CRASH-LOOP at boot with
# "Invalid characters in API key" — the service just disappears.
# SUPERTOKENS_API_KEY=your-key-with-hyphens-only

# === Cache Provider ===
# "redis"     (default) — Standard Redis cache. Celery (background jobs)
#                         REQUIRES a reachable redis — keep "redis" in
#                         COMPOSE_PROFILES or point REDIS_URL elsewhere.
# "dragonfly"           — Multi-threaded Redis drop-in (profile: dragonfly)
#CACHE_PROVIDER=dragonfly
# REDIS_URL=redis://your-external-redis:6379

# === Supabase Configuration (Required when AUTH_PROVIDER=supabase) ===
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_JWT_SECRET=your-jwt-secret
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# 4. OPTIONAL
# =============================================================================

# === Observability (unset = telemetry off) ===
# SPA: Sentry error tracking + PostHog product analytics.
# VITE_SENTRY_DSN=
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# Backend (FastAPI): Sentry error tracking
# SENTRY_DSN=

# === Email Provider (Platform-Level) ===
# Pick ONE. Resend recommended for simplicity.

# Option A: Resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx

# Option B: Mailgun
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_REGION=us                     # "us" or "eu"

# Sender identity (used by whichever provider is active)
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=Frontbase

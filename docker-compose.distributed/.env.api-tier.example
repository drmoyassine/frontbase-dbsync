# =============================================================================
# API Tier (Machine A) Environment Variables
# =============================================================================
# Copy to .env.api-tier and fill in the values before deploying docker-compose.api-tier.yml

# === 1. Network / Cluster Topology ===
BACKEND_PORT=8000
EDGE_URL=http://MACHINE_C_IP:3002
REDIS_URL=redis://redis:6379

# === 2. API / Backend Specific Configuration ===
# Security (REQUIRED)
SECRET_KEY=change-me-in-production
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-in-production
REDIS_TOKEN=change-me-in-production

# Deployment Mode
# "self-host" (default) or "cloud" (multi-tenant SaaS)
DEPLOYMENT_MODE=cloud

# Database Connection (Pointing to Machine B)
DATABASE_URL=postgresql://frontbase:your-secure-password@MACHINE_B_IP:5432/frontbase

# Email Settings (Optional)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
# EMAIL_FROM=noreply@yourdomain.com

# Observability (Optional)
# SENTRY_DSN=

# =============================================================================
# Frontbase — Environment Configuration
# =============================================================================
# Copy to .env, fill in the values, then: docker-compose up -d
# =============================================================================

# === Required ===
SECRET_KEY=change-me-in-production
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-in-production

# Your site's public URL (for preview links after publish)
# PUBLIC_URL=https://yoursite.com

# Webhook authentication keys (comma-separated)
# API_KEYS=key1,key2

# === Deployment Mode ===
# "self-host" (default) — single-tenant, env-var admin, session cookies
# "cloud"               — multi-tenant SaaS, DB-backed users, JWT auth
# DEPLOYMENT_MODE=cloud
# VITE_DEPLOYMENT_MODE=cloud

# === Authentication Provider (Cloud mode only) ===
# "supertokens" (default cloud) — Email/password auth with SuperTokens
# "supabase"                — Email/password + OAuth auth with Supabase
# AUTH_PROVIDER=supertokens
# VITE_AUTH_PROVIDER=supertokens

# === Supabase Configuration (Required when AUTH_PROVIDER=supabase) ===
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_JWT_SECRET=your-jwt-secret
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_PROJECT_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# === Observability (Cloud mode only — all optional; unset = telemetry off) ===
# SPA: Sentry error tracking + PostHog product analytics. Both no-op when blank
# and in self-host mode, so self-host builds ship with zero third-party telemetry.
# VITE_SENTRY_DSN=
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# Backend (FastAPI): Sentry error tracking (pure-ASGI; does not affect SSE streaming)
# SENTRY_DSN=

# === Cloud Mode Only — External Database URL ===
# For Supabase: Copy the connection string exactly as shown in the Dashboard (IPv4 or Session Pooler).
# The platform will automatically normalize the dialect (e.g. postgresql:// -> postgresql+psycopg2://)
# DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# === PostgreSQL (default: SQLite, uncomment to switch) ===
# COMPOSE_PROFILES=postgresql
# DB_PASSWORD=your-secure-password

# === Distributed / Multi-Machine (uncomment when splitting services) ===
# BACKEND_URL=http://MACHINE_A_IP:8000
# EDGE_URL=http://MACHINE_C_IP:3002

# === Email Provider (Platform-Level) ===
# Pick ONE. Resend recommended for simplicity.

# Option A: Resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx

# Option B: Mailgun
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_REGION=us                     # "us" or "eu"

# Sender identity (used by whichever provider is active)
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=Frontbase
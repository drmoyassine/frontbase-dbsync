# =============================================================================
# Data Tier (Machine B) Environment Variables
# =============================================================================
# Copy to .env.data-tier and fill in the values before deploying docker-compose.data-tier.yml

# === 1. Network / Cluster Topology ===
POSTGRES_PORT=5432

# === 2. Database Specific Configuration ===
DB_PASSWORD=your-secure-password

# === 3. SuperTokens Core (OPTIONAL — only when the API tier uses supertokens) ===
# Enable the core on this machine:
# COMPOSE_PROFILES=supertokens
# SUPERTOKENS_PORT=3567
#
# The API key the backend must present. ⚠️  This port is published — firewall
# it to the API tier's IP and ALWAYS set a strong key here (don't rely on the
# built-in default across machines).
# ⚠️  Charset: alphanumerics, '-' and '=' ONLY. An underscore makes the core
# crash-loop at boot ("Invalid characters in API key").
# SUPERTOKENS_API_KEY=your-key-with-hyphens-only
